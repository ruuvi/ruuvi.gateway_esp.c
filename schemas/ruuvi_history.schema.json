{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "http://ruuvi.com/schemas/ruuvi_history.schema.json",
  "type": "object",
  "title": "Accumulated time-stamped data from Bluetooth sensors returned in response to HTTP GET /history",
  "additionalProperties": false,
  "required": [
    "data"
  ],
  "properties": {
    "data": {
      "type": "object",
      "title": "Data-object containing accumulated data from Bluetooth-sensors",
      "additionalProperties": false,
      "required": [
        "coordinates",
        "timestamp",
        "gw_mac",
        "tags"
      ],
      "properties": {
        "coordinates": {
          "type": "string",
          "title": "GPS-coordinates of Ruuvi Gateway (optional)",
          "examples": [
            ""
          ]
        },
        "timestamp": {
          "type": "integer",
          "title": "Timestamp (Unix-time) when this JSON is generated by Gateway",
          "examples": [
            1665742208
          ]
        },
        "gw_mac": {
          "type": "string",
          "pattern": "^([0-9A-Fa-f]{2}[:-]){5}([0-9A-Fa-f]{2})$",
          "title": "MAC-address of Ruuvi Gateway",
          "examples": [
            "C8:25:2D:8E:9C:2C"
          ]
        },
        "tags": {
          "type": "object",
          "title": "Object containing messages from Bluetooth sensors, with MAC addresses as keys",
          "additionalProperties": false,
          "patternProperties": {
            "^([0-9A-Fa-f]{2}[:-]){5}([0-9A-Fa-f]{2})$": {
              "type": "object",
              "title": "MAC-address of Bluetooth-sensor",
              "additionalProperties": false,
              "required": [
                "rssi",
                "timestamp",
                "ble_phy",
                "ble_chan",
                "data"
              ],
              "properties": {
                "rssi": {
                  "type": "integer",
                  "title": "RSSI",
                  "examples": [
                    -71
                  ]
                },
                "timestamp": {
                  "type": "integer",
                  "title": "Timestamp (Unix-time) when the message from Bluetooth-sensor was received by Gateway",
                  "examples": [
                    1653633986
                  ]
                },
                "ble_phy": {
                  "type": "string",
                  "enum": ["1M", "2M", "Coded"],
                  "title": "BLE PHY used for communication",
                  "examples": [
                    "1M",
                    "2M",
                    "Coded"
                  ]
                },
                "ble_chan": {
                  "type": "integer",
                  "title": "BLE channel used for communication",
                  "examples": [
                    37,
                    38,
                    39
                  ]
                },
                "ble_tx_power": {
                  "type": "integer",
                  "title": "BLE Tx Power",
                  "examples": [
                    7,
                    8,
                    9
                  ]
                },
                "data": {
                  "type": "string",
                  "title": "Relayed message from Bluetooth-sensor in hex encoding",
                  "pattern": "^([0-9A-Fa-f]{2})+$",
                  "examples": [
                    "0201061BFF99040513C85714C7CC00240008041CAB76F41C3CC6A5B9E0AD06"
                  ]
                },
                "dataFormat": {
                  "type": "integer",
                  "title": "Data format",
                  "examples": [
                    5,
                    6
                  ]
                },
                "temperature": {
                  "type": ["number", "null"],
                  "title": "Temperature in C",
                  "examples": [
                    null,
                    28,
                    28.0,
                    28.745
                  ]
                },
                "humidity": {
                  "type": ["number", "null"],
                  "title": "Humidity in percentage",
                  "examples": [
                    null,
                    45,
                    45.3050
                  ]
                },
                "pressure": {
                  "type": ["number", "null"],
                  "title": "Pressure in Pa",
                  "examples": [
                    null,
                    150812
                  ]
                },
                "accelX": {
                  "type": ["number", "null"],
                  "title": "RuuviTag: AccelX",
                  "examples": [
                    null,
                    0.012,
                    -0.012
                  ]
                },
                "accelY": {
                  "type": ["number", "null"],
                  "title": "RuuviTag: AccelY",
                  "examples": [
                    null,
                    0.012,
                    -0.012
                  ]
                },
                "accelZ": {
                  "type": ["number", "null"],
                  "title": "RuuviTag: AccelZ",
                  "examples": [
                    null,
                    0.012,
                    -0.012
                  ]
                },
                "movementCounter": {
                  "type": "integer",
                  "title": "RuuviTag: Movement counter",
                  "examples": [
                    0,
                    164
                  ]
                },
                "voltage": {
                  "type": ["number", "null"],
                  "title": "RuuviTag: Battery voltage",
                  "examples": [
                    null,
                    2.556
                  ]
                },
                "txPower": {
                  "type": "integer",
                  "title": "RuuviTag: Tx power",
                  "examples": [
                    -32
                  ]
                },
                "measurementSequenceNumber": {
                  "type": "integer",
                  "title": "Measurement sequence number",
                  "examples": [
                    19807
                  ]
                },
                "CO2": {
                  "type": ["number", "null"],
                  "title": "RuuviAir: CO2",
                  "examples": [
                    null,
                    130,
                    777
                  ]
                },
                "PM1.0": {
                  "type": ["number", "null"],
                  "title": "RuuviAir: PM1.0",
                  "examples": [
                    null,
                    9.6,
                    99.5
                  ]
                },
                "PM2.5": {
                  "type": ["number", "null"],
                  "title": "RuuviAir: PM2.5",
                  "examples": [
                    null,
                    9.6,
                    99.5
                  ]
                },
                "PM4.0": {
                  "type": ["number", "null"],
                  "title": "RuuviAir: PM4.0",
                  "examples": [
                    null,
                    9.6,
                    99.5
                  ]
                },
                "PM10.0": {
                  "type": ["number", "null"],
                  "title": "RuuviAir: PM10.0",
                  "examples": [
                    null,
                    9.6,
                    99.5
                  ]
                },
                "VOC": {
                  "type": ["number", "null"],
                  "title": "RuuviAir: VOC",
                  "examples": [
                    null,
                    10,
                    777
                  ]
                },
                "NOx": {
                  "type": ["number", "null"],
                  "title": "RuuviAir: NOx",
                  "examples": [
                    null,
                    1,
                    2
                  ]
                },
                "luminosity": {
                  "type": ["number", "null"],
                  "title": "RuuviAir: luminosity",
                  "examples": [
                    null,
                    1000,
                    14560
                  ]
                },
                "sound_inst_dba": {
                  "type": ["number", "null"],
                  "title": "RuuviAir: sound_inst_dba",
                  "examples": [
                    null,
                    79.5
                  ]
                },
                "sound_avg_dba": {
                  "type": ["number", "null"],
                  "title": "RuuviAir: sound_avg_dba",
                  "examples": [
                    null,
                    79.5
                  ]
                },
                "sound_peak_spl_db": {
                  "type": ["number", "null"],
                  "title": "RuuviAir: sound_peak_spl_db",
                  "examples": [
                    null,
                    79.5
                  ]
                },
                "flag_calibration_in_progress": {
                  "type": "boolean",
                  "title": "RuuviAir: Calibration in progress flag",
                  "examples": [
                    true,
                    false
                  ]
                },
                "flag_button_pressed": {
                  "type": "boolean",
                  "title": "RuuviAir: Button pressed flag",
                  "examples": [
                    true,
                    false
                  ]
                },
                "flag_rtc_running_on_boot": {
                  "type": "boolean",
                  "title": "RuuviAir: RTC running on boot flag",
                  "examples": [
                    true,
                    false
                  ]
                },
                "id": {
                  "type": "string",
                  "title": "MAC-address of Bluetooth-sensor or shortened identifier (least 3 bytes of RuuviAir MAC-address received in legacy BLE advertisement)",
                  "pattern": "^(([0-9A-Fa-f]{2}[:-]){5}|([0-9A-Fa-f]{2}[:-]){2})([0-9A-Fa-f]{2})$",
                  "examples": [
                    "F4:1F:0C:28:CB:D6",
                    "28:CB:D6"
                  ]
                }
              }
            }
          },
          "examples": [
            {
              "F4:1F:0C:28:CB:D6": {
                "rssi": -34,
                "timestamp": 1665742208,
                "ble_phy": "1M",
                "ble_chan": 37,
                "data": "0201061BFF99040514EE4C08C5370018FFB803E8A7F6E67A8EF41F0C28CBD6"
              },
              "C6:A5:B9:E0:AD:06": {
                "rssi": -33,
                "timestamp": 1665742208,
                "ble_phy": "1M",
                "ble_chan": 39,
                "data": "0201061BFF99040514A24454C4FF0030FFFC0420AB76207A89C6A5B9E0AD06"
              },
              "F4:C6:46:2C:3E:B4": {
                "rssi": -46,
                "timestamp": 1687922292,
                "ble_phy": "1M",
                "ble_chan": 39,
                "data": "0201061BFF99040515EF481EC6630038001003F08376502051F4C6462C3EB4",
                "dataFormat": 5,
                "temperature": 28.075,
                "humidity": 46.1550,
                "pressure": 150787,
                "accelX": 0.056,
                "accelY": 0.016,
                "accelZ": 1.008,
                "movementCounter": 80,
                "voltage": 2.651,
                "txPower": -32,
                "measurementSequenceNumber": 8273,
                "id": "F4:C6:46:2C:3E:B4"
              }
            }
          ]
        }
      }
    }
  },
